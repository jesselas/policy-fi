---
layout: base.njk
title: AI for Economists
wide: true
description: "Curated collection of AI and LLM resources for economists — research papers, coding guides, tools, courses, and more. Maintained by Jesse Lastunen."
jsonLd:
  "@context": "https://schema.org"
  "@type": "WebPage"
  name: "AI for Economists"
  url: "https://policy.fi/ai-econ/"
  description: "Curated collection of AI and LLM resources for economists — research papers, coding guides, tools, courses, and more."
  author:
    "@type": "Person"
    name: "Jesse Lastunen"
    url: "https://policy.fi"
  about:
    - "@type": "Thing"
      name: "Artificial Intelligence in Economics"
    - "@type": "Thing"
      name: "Large Language Models for Economic Research"
    - "@type": "Thing"
      name: "AI Tools for Economists"
  keywords: "AI economics, LLM economists, AI tools research, Claude Code economics, generative AI research, prompts for economists"
---

{% set categoryOrder = [
  "Research Papers",
  "Courses & Learning",
  "Coding with AI",
  "AI Tools for Research",
  "Talks & Videos",
  "Commentary & Analysis"
] %}

{% set typeOrderList = ["paper", "guide", "tool", "course", "video", "article", "thread", "other"] %}

{% set nonInternal = [] %}
{% for entry in ai_resources %}
  {% if not entry.internal %}
    {% set nonInternal = (nonInternal.push(entry), nonInternal) %}
  {% endif %}
{% endfor %}

{% set recent20 = nonInternal.slice(-20) %}

{% set highlightEntries = [] %}
{% for entry in nonInternal %}
  {% if entry.highlight %}
    {% set highlightEntries = (highlightEntries.push(entry), highlightEntries) %}
  {% endif %}
{% endfor %}

{% set presentTypes = [] %}
{% for t in typeOrderList %}
  {% set tCount = 0 %}
  {% for entry in nonInternal %}
    {% if entry.type == t %}{% set tCount = tCount + 1 %}{% endif %}
  {% endfor %}
  {% if tCount > 0 %}
    {% set presentTypes = (presentTypes.push({ name: t, count: tCount }), presentTypes) %}
  {% endif %}
{% endfor %}

{% macro resourceCard(entry, idx) %}
<article class="resource-card{% if entry.featured %} featured{% endif %}" data-category="{{ entry.category }}" data-type="{{ entry.type }}" data-featured="{{ '1' if entry.featured else '' }}" data-index="{{ idx }}" data-date="{{ entry.date or '' }}" data-author-sort="{{ entry.author | lastName }}" data-searchable="{{ (entry.title + ' ' + (entry.author or '') + ' ' + entry.description + ' ' + entry.tags | join(' ')) | lower }}">
  <div class="card-top">
    <span class="card-type">{{ entry.type }}</span>
    {% if entry.featured %}<span class="card-star" title="Featured">★</span>{% endif %}
    {% if entry.date %}<span class="card-date">{{ entry.date }}</span>{% endif %}
  </div>
  <h3 class="card-title"><a href="{{ entry.url }}">{{ entry.title }}</a></h3>
  {% if entry.author %}<div class="card-meta">{{ entry.author }}</div>{% endif %}
  <div class="card-description">{{ entry.description | safe }}</div>
  <div class="card-tags">
    {% for tag in entry.tags %}<span class="tag">{{ tag }}</span> {% endfor %}
  </div>
</article>
{% endmacro %}

<h1>AI for Economists</h1>

<p class="page-intro">A curated collection of resources for economists working with AI and LLMs — from research papers and courses to practical tools and coding guides.</p>

<div class="library-layout">

  <aside class="library-sidebar" aria-label="Library filters and navigation">
    <div class="sidebar-search search-wrapper">
      <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      <input type="search" class="search-input" id="resource-search" placeholder="Search…" aria-label="Search resources">
      <span class="search-kbd" aria-hidden="true">/</span>
    </div>

    <span class="sidebar-label">Categories</span>
    <nav class="cat-nav" id="category-filters" aria-label="Resource categories">
      <button class="cat-link" data-category="Recently Added">
        <span class="cat-dot"></span>
        <span class="cat-name">Recently Added</span>
        <span class="cat-count">{{ recent20.length }}</span>
      </button>
      <button class="cat-link" data-category="Highlights">
        <span class="cat-dot"></span>
        <span class="cat-name">Highlights</span>
        <span class="cat-count">{{ highlightEntries.length }}</span>
      </button>
      {% for cat in categoryOrder %}
        {% set catEntries = [] %}
        {% for entry in nonInternal %}
          {% if entry.category == cat %}
            {% set catEntries = (catEntries.push(entry), catEntries) %}
          {% endif %}
        {% endfor %}
        {% if catEntries.length > 0 %}
        <button class="cat-link" data-category="{{ cat }}">
          <span class="cat-dot"></span>
          <span class="cat-name">{{ cat }}</span>
          <span class="cat-count">{{ catEntries.length }}</span>
        </button>
        {% endif %}
      {% endfor %}
    </nav>

    <div class="sidebar-extra">
      <span class="sidebar-label">Type</span>
      <div class="type-chips" id="type-filters" role="group" aria-label="Filter by resource type">
        {% for t in presentTypes %}
        <button class="type-chip" data-type="{{ t.name }}">{{ t.name }}</button>
        {% endfor %}
      </div>

      <span class="sidebar-label">Show</span>
      <button class="featured-toggle" id="featured-toggle" aria-pressed="false">
        <span class="toggle-track" aria-hidden="true"></span>
        <span>Featured only</span>
      </button>
    </div>

    <div class="sidebar-meta">
      <span id="results-count">{{ nonInternal.length }} resources</span><br>
      <button class="sidebar-reset" id="filter-reset">Reset filters</button>
    </div>
  </aside>

  <div class="library-content" data-view="list" id="library-content">

    <div class="library-toolbar">
      <div class="toolbar-group" id="library-sort" role="group" aria-label="Sort resources">
        <span class="toolbar-label">Sort</span>
        <button type="button" class="sort-btn" data-sort="added"><span class="sort-full">Date added</span><span class="sort-short">Added</span></button>
        <button type="button" class="sort-btn" data-sort="date"><span class="sort-full">Date of reference</span><span class="sort-short">Date</span></button>
        <button type="button" class="sort-btn" data-sort="author"><span class="sort-full">Last name</span><span class="sort-short">Name</span></button>
      </div>
      <div class="toolbar-end">
      <span class="toolbar-updated">{{ nonInternal.length }} resources · updated {{ buildMonth }}</span>
      <div class="toolbar-group" role="group" aria-label="View options">
        <span class="toolbar-label">View</span>
        <button type="button" class="view-btn" data-view="cards" aria-label="Card view" title="Card view">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><rect x="3" y="3" width="7" height="7" rx="1"></rect><rect x="14" y="3" width="7" height="7" rx="1"></rect><rect x="3" y="14" width="7" height="7" rx="1"></rect><rect x="14" y="14" width="7" height="7" rx="1"></rect></svg>
        </button>
        <button type="button" class="view-btn active" data-view="list" aria-label="List view" title="List view">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
        </button>
      </div>
      </div>
    </div>

    <section class="lib-section" id="recently-added" data-group-category="Recently Added">
      <h2 class="lib-section-head" data-category="Recently Added">
        <span class="cat-dot"></span>
        Recently Added
        <span class="lib-count">{{ recent20.length }} entries</span>
      </h2>
      <div class="lib-grid">
        {% for entry in recent20 %}{{ resourceCard(entry, loop.index0) }}{% endfor %}
      </div>
    </section>

    <section class="lib-section" id="highlights" data-group-category="Highlights">
      <h2 class="lib-section-head" data-category="Highlights">
        <span class="cat-dot"></span>
        Highlights
        <span class="lib-count">{{ highlightEntries.length }} entries</span>
      </h2>
      <div class="lib-grid">
        {% for entry in highlightEntries %}{{ resourceCard(entry, loop.index0) }}{% endfor %}
      </div>
    </section>

    {% for cat in categoryOrder %}
      {% set catEntries = [] %}
      {% for entry in nonInternal %}
        {% if entry.category == cat %}
          {% set catEntries = (catEntries.push(entry), catEntries) %}
        {% endif %}
      {% endfor %}
      {% if catEntries.length > 0 %}
      <section class="lib-section" id="{{ cat | lower | replace(' & ', '-') | replace(' ', '-') }}" data-group-category="{{ cat }}">
        <h2 class="lib-section-head" data-category="{{ cat }}">
          <span class="cat-dot"></span>
          {{ cat }}
          <span class="lib-count">{{ catEntries.length }} entries</span>
        </h2>
        <div class="lib-grid">
          {% for entry in catEntries %}{{ resourceCard(entry, loop.index0) }}{% endfor %}
        </div>
      </section>
      {% endif %}
    {% endfor %}

    <div class="no-results" id="no-results" style="display: none;">
      No resources match your current filters. Try broadening your search or resetting filters.
    </div>

  </div>
</div>
