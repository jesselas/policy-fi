layout: base.njk
title: AI for Economists
description: "Curated collection of AI and LLM resources for economists — research papers, coding guides, tools, courses, and more. Maintained by Jesse Lastunen."
jsonLd:
  "@context": "https://schema.org"
  "@type": "WebPage"
  name: "AI for Economists"
  url: "https://policy.fi/ai-econ/"
  description: "Curated collection of AI and LLM resources for economists — research papers, coding guides, tools, courses, and more."
  author:
    "@type": "Person"
    name: "Jesse Lastunen"
    url: "https://policy.fi"
  about:
    - "@type": "Thing"
      name: "Artificial Intelligence in Economics"
    - "@type": "Thing"
      name: "Large Language Models for Economic Research"
    - "@type": "Thing"
      name: "AI Tools for Economists"
  keywords: "AI economics, LLM economists, AI tools research, Claude Code economics, generative AI research, prompts for economists"
---

{% set categoryOrder = [
  "Research Papers",
  "Courses & Learning",
  "Coding with AI",
  "AI Tools for Research",
  "Talks & Videos",
  "Prompt Engineering",
  "Commentary & Analysis",
  "Policy & Governance"
] %}

{% set typeIcons = {
  "paper": "📄",
  "course": "🎓",
  "video": "▶",
  "tool": "🔧",
  "article": "📝",
  "guide": "📖",
  "thread": "💬",
  "other": "🔗"
} %}

{% set nonInternal = [] %}
{% for entry in ai_resources %}
  {% if not entry.internal %}
    {% set nonInternal = (nonInternal.push(entry), nonInternal) %}
  {% endif %}
{% endfor %}

<h1>AI for Economists</h1>

<p class="page-intro">A curated collection of resources for economists working with AI and LLMs — from research papers and courses to practical tools and coding guides. Maintained by Jesse Lastunen. Last updated: March 2026.</p>

<div class="info-section">
  <div class="highlight-tabs">
    <button class="section-label highlight-tab active" data-tab="highlights">Highlights</button>
    <button class="section-label highlight-tab" data-tab="recent">Recently Added</button>
  </div>
  <div class="highlights-grid" id="highlights-panel">
    {% for entry in nonInternal %}
      {% if entry.highlight %}
      <div class="highlight-card">
        <div class="highlight-title"><a href="{{ entry.url }}">{{ entry.title }}</a></div>
        <div class="highlight-meta">{% if entry.author %}{{ entry.author }}{% endif %}{% if entry.author and entry.date %} · {% endif %}{% if entry.date %}{{ entry.date }}{% endif %}</div>
        <div class="highlight-desc">{{ entry.highlightDesc or (entry.description | truncate(180)) }}</div>
      </div>
      {% endif %}
    {% endfor %}
  </div>
  <div class="highlights-grid" id="recent-panel" style="display: none;">
    {% for entry in recentResources %}
    <div class="highlight-card">
      <div class="highlight-title"><a href="{{ entry.url }}">{{ entry.title }}</a></div>
      <div class="highlight-meta">{% if entry.author %}{{ entry.author }}{% endif %}{% if entry.author and entry.date %} · {% endif %}{% if entry.date %}{{ entry.date }}{% endif %}</div>
      <div class="highlight-desc">{{ entry.shortDescription or (entry.description | truncate(150)) }}</div>
    </div>
    {% endfor %}
  </div>
</div>

<div class="divider">·</div>

<div class="info-section">
  <span class="section-label">Browse all resources</span>

  <div class="search-wrapper">
    <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
    <input type="search" class="search-input" id="resource-search" placeholder="Search by title, author, or keyword...">
  </div>

  <div class="filter-pills" id="category-filters">
    <button class="filter-pill active" data-category="all">All ({{ nonInternal.length }})</button>
    {% for cat in categoryOrder %}
      {% set catEntries = [] %}
      {% for entry in nonInternal %}
        {% if entry.category == cat %}
          {% set catEntries = (catEntries.push(entry), catEntries) %}
        {% endif %}
      {% endfor %}
      {% if catEntries.length > 0 %}
      <button class="filter-pill" data-category="{{ cat }}">{{ cat }} ({{ catEntries.length }})</button>
      {% endif %}
    {% endfor %}
  </div>

  <div class="results-count" id="results-count" style="display:none;"></div>
</div>

{% for cat in categoryOrder %}
  {% set catEntries = [] %}
  {% for entry in nonInternal %}
    {% if entry.category == cat %}
      {% set catEntries = (catEntries.push(entry), catEntries) %}
    {% endif %}
  {% endfor %}
  {% if catEntries.length > 0 %}
  <div class="accordion-section resource-group" data-group-category="{{ cat }}">
    <div class="accordion-header" aria-expanded="false">
      <span>{{ cat }} <span class="accordion-count">{{ catEntries.length }}</span></span>
      <span class="accordion-indicator"></span>
    </div>
    <div class="accordion-content">
      <div class="accordion-body">
        {% for entry in catEntries %}
        <div class="resource-card{% if entry.featured %} featured{% endif %}" data-category="{{ entry.category }}" data-type="{{ entry.type }}" data-tags="{{ entry.tags | join(',') }}" data-searchable="{{ (entry.title + ' ' + (entry.author or '') + ' ' + entry.description + ' ' + entry.tags | join(' ')) | lower }}">
          <span class="card-type-icon">{{ typeIcons[entry.type] or "🔗" }}</span>
          <div class="card-title"><a href="{{ entry.url }}">{{ entry.title }}</a></div>
          <div class="card-meta">{% if entry.author %}{{ entry.author }}{% endif %}{% if entry.author and entry.date %} · {% endif %}{% if entry.date %}{{ entry.date }}{% endif %}</div>
          <div class="card-description">{{ entry.description | safe }}</div>
          <div class="card-tags">
            {% for tag in entry.tags %}<span class="tag">{{ tag }}</span> {% endfor %}
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
  {% endif %}
{% endfor %}

<div class="no-results" id="no-results" style="display: none;">
  No resources match your current filters. Try broadening your search or resetting filters.
</div>

<div class="divider">·</div>

